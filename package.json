{
  "name": "ciscovpn",
  "version": "0.1.0",
  "description": "Stream Deck+ plugin for Cisco Secure Client VPN control",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "link-plugin": "streamdeck link com.kanai.ciscovpn.sdPlugin",
    "pack": "npm run build && streamdeck pack com.kanai.ciscovpn.sdPlugin --output . --force"
  },
  "dependencies": {
    "@elgato/streamdeck": "latest"
  },
  "devDependencies": {
    "@elgato/cli": "latest",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.2.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "~20.15.0",
    "rollup": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2"
  }
}
